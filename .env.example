# ── MongoDB ───────────────────────────────────────────────
# Option A: full URI (takes precedence when set)
# MONGODB_URI=mongodb://localhost:27017/topichub

# Option B: individual fields (used when MONGODB_URI is absent)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=topichub
# MONGODB_USERNAME=
# MONGODB_PASSWORD=
# MONGODB_AUTH_SOURCE=admin
# MONGODB_REPLICA_SET=

# TLS – path to CA certificate (works with both Option A and B)
# MONGODB_CA_CERT_PATH=./cert/mongo-replica-bd6ee7d59264/ca_certificate.pem

# ── Server ────────────────────────────────────────────────
PORT=3000
LOG_FORMAT=pretty
# TOPICHUB_JSON_BODY_LIMIT=25mb   # Nest JSON + form body limit (webhooks, skill publish); default 15mb
# TOPICHUB_AGENT_TIMEOUT_MS=0     # Per-task claude/codex subprocess cap under serve (ms). 0 = no spawn timeout; default 1800000 (30m)
# TOPICHUB_DISPATCH_CLAIM_TTL_MS=3600000   # How long a claimed dispatch stays reserved (default 3600000 = 1h). Serve also POSTs touch-claim every 2m while running.
# TOPICHUB_AGENT_CWD=/abs/path/to/project   # Override agent cwd under `serve` (default: INIT_CWD from pnpm/npm, else process.cwd()). Per-topic: topic.metadata.executorCwd
# TOPICHUB_DISABLE_INTERACTIVE_QA=1        # Do not post IM Q&A / second agent turn for clarify-style output (Question N of M, TOPICHUB_QA_PENDING)
# TOPICHUB_INTERACTIVE_QA_MAX_ROUNDS=20    # Max clarify IM rounds per dispatch (each round: postQuestion → /answer → next agent execute)
# TOPICHUB_IM_COMPLETE_MAX_CHARS=8000      # Optional extra cap on IM completion body (min with per-platform budget: Discord ~1976, Feishu ~29k, …)
# MASTER_SECRET=          # required in production; derives ENCRYPTION_KEY + TOKEN_SECRET via HKDF
# ENCRYPTION_KEY=         # optional override (takes precedence over HKDF-derived value)
# TOKEN_SECRET=           # optional override (takes precedence over HKDF-derived value)
# SKILLS_DIR=./skills

# ── OpenClaw IM Bridge ────────────────────────────────────
# Two modes — pick ONE:
#
# Mode A: Auto-managed (core spawns openclaw gateway as a child process)
# Platform is auto-detected from the webhook or inferred from configured channels.
# TOPICHUB_BRIDGE_WEBHOOK_URL=http://localhost:3000/webhooks/openclaw
# TOPICHUB_BRIDGE_PORT=18789
# TOPICHUB_BRIDGE_DISCORD_BOT_TOKEN=
# TOPICHUB_BRIDGE_FEISHU_APP_ID=
# TOPICHUB_BRIDGE_FEISHU_APP_SECRET=
# TOPICHUB_BRIDGE_FEISHU_DOMAIN=feishu           # "feishu" or "lark"
# TOPICHUB_BRIDGE_TELEGRAM_BOT_TOKEN=
# TOPICHUB_BRIDGE_SLACK_BOT_TOKEN=
# TOPICHUB_BRIDGE_SLACK_APP_TOKEN=
# TOPICHUB_BRIDGE_WEIXIN_ENABLED=true      # requires: openclaw plugins install @tencent-weixin/openclaw-weixin && openclaw channels login --channel openclaw-weixin
#
# Mode B: External (connect to a separately deployed openclaw gateway)
# TOPICHUB_OPENCLAW_GATEWAY_URL=http://localhost:18789
# TOPICHUB_OPENCLAW_TOKEN=your-bearer-token
# TOPICHUB_OPENCLAW_WEBHOOK_SECRET=your-hmac-secret
