{
  "name": "@topichub/core",
  "version": "0.0.3",
  "description": "Framework-agnostic core library for TopicHub - event topic management, skill pipeline, and AI-driven workflows",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist/",
    "vendor/bridge/package.json",
    "vendor/bridge/dist/",
    "vendor/bridge/docs/",
    "vendor/bridge/extensions/",
    "vendor/bridge/node_modules/",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "node ./scripts/sync-bridge-vendor.mjs --bridge && pnpm build",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@typegoose/typegoose": "^12.0.0",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.1.0",
    "mongoose": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.19.39",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}