{
  "name": "github-trending",
  "version": "1.0.0",
  "description": "GitHub Trending page scraper — fetches and parses top trending repositories",
  "main": "./src/index.ts",
  "topichub": {
    "category": "adapter",
    "sourceSystem": "github-trending",
    "webhookPath": "/webhook/github-trending",
    "supportedEvents": ["trending_snapshot"],
    "auth": {
      "type": "none"
    }
  },
  "dependencies": {
    "@topichub/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.5.0"
  }
}
