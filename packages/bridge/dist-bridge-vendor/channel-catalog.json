          "systemImage": "bubble.left.and.bubble.right",
          "markdownCapable": true,
          "configuredState": {
            "specifier": "./configured-state",
            "exportName": "hasDiscordConfiguredState"
          }
        },
        "install": {
          "npmSpec": "@openclaw/discord",
          "defaultChoice": "npm"
        }
      }
    },
    {
